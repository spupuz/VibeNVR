+    const [streamMode, setStreamMode] = useState(() => {
+        const preferred = camera.live_view_mode || 'auto';
+        const hasWebCodecs = 'VideoDecoder' in window;
+
+        if (preferred === 'mjpeg') return 'fallback';
+        if (preferred === 'webcodecs') return 'webcodecs';
