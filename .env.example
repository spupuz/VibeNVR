# VibeNVR Environment Configuration
# Copy this file to .env and modify it for your environment.

# ─────────────────────────────────────────────────────────────────────────────
# 🔑 SECURITY (CRITICAL)
# ─────────────────────────────────────────────────────────────────────────────

# Secret key used for signing JWT tokens. 
# Generate a strong one with: openssl rand -hex 32
# If left as default in production, the app will not start.
# Generate a strong one with: openssl rand -hex 32
SECRET_KEY=paste_your_random_32_or_64_char_hex_here

# Shared secret between backend and engine for internal communication.
# Generate a strong one with: openssl rand -hex 32
WEBHOOK_SECRET=paste_another_random_hex_here

# Set to true to bypass strict SECRET_KEY checks (NOT RECOMMENDED).
ALLOW_WEAK_SECRET=false

# ─────────────────────────────────────────────────────────────────────────────
# 🌐 NETWORK & ACCESS
# ─────────────────────────────────────────────────────────────────────────────

# Port for the Web UI (Frontend)
VIBENVR_FRONTEND_PORT=8080

# Port for the Backend API (Internal/Debugging)
VIBENVR_BACKEND_PORT=5005

# Timezone (e.g., Europe/Rome, America/New_York)
TZ=Europe/Rome

# Comma-separated list of allowed CORS origins (e.g., https://yourdomain.com)
# If empty, only localhost is allowed.
ALLOWED_ORIGINS=

# Set to 'auto' (default) to automatically detect HTTPS/HTTP.
# Set to 'true' to force Secure cookies (requires HTTPS).
# Set to 'false' to disable Secure flag (local testing only).
COOKIE_SECURE=auto

# ─────────────────────────────────────────────────────────────────────────────
# 💾 STORAGE & DATABASE
# ─────────────────────────────────────────────────────────────────────────────

# Host path for recordings and system data. 
# Relative paths (./data) or absolute paths (/mnt/storage/vibe) are supported.
# VIBENVR_DATA=./data

# Host path for PostgreSQL database files.
# VIBENVR_DB_DATA=./db_data

# Database Credentials
POSTGRES_USER=vibenvr
POSTGRES_PASSWORD=vibenvrpass
POSTGRES_DB=vibenvr

# ─────────────────────────────────────────────────────────────────────────────
# ⚡ HARDWARE ACCELERATION
# ─────────────────────────────────────────────────────────────────────────────

# Enable GPU-accelerated video processing (FFmpeg).
HW_ACCEL=false

# GPU Type: auto, nvidia, intel (VAAPI), amd (VAAPI).
HW_ACCEL_TYPE=auto

# ─────────────────────────────────────────────────────────────────────────────
# 🛡️ AUTOMATIC BACKUP (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# Enable automatic configuration backups to /data/backups/
# BACKUP_AUTO_ENABLED=false

# Backup frequency in hours (default: 24)
# BACKUP_AUTO_FREQUENCY_HOURS=24

# Number of backup files to retain (default: 7)
# BACKUP_AUTO_RETENTION=7

# ─────────────────────────────────────────────────────────────────────────────
# 📂 CUSTOM STORAGE PROFILES (Optional)
# ─────────────────────────────────────────────────────────────────────────────

# You can map these in the Engine and Backend via docker-compose.yml
# VIBENVR_STORAGE_SSD=/mnt/ssd/recordings
# VIBENVR_STORAGE_NAS=/mnt/nas/vibe
